# Shared
APP_ENV=development
APP_BASE_URL=http://localhost:3000
MARKETPLACE_ONLY_MODE=true

# Django
DJANGO_SECRET_KEY=development-only-change-me
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_CSRF_TRUSTED_ORIGINS=http://localhost:3000
DJANGO_REQUIRE_API_ORIGIN=false
DATABASE_URL=postgresql://airport_app:change-me@127.0.0.1:5432/airport_transfer
DJANGO_LOG_LEVEL=INFO
# Enable only after HTTPS and all subdomains have been validated for preload.
DJANGO_HSTS_PRELOAD=false
# Set to 1 only when exactly one trusted reverse proxy is in front of Django.
DRF_NUM_PROXIES=0
TRUSTED_PROXY_NETWORKS=127.0.0.1/32,::1/128
# Production defaults this gate to true and requires explicit administrator/VPN CIDRs.
STAFF_NETWORK_GATE_ENABLED=false
STAFF_ALLOWED_NETWORKS=

# Next.js server-side API base; browser calls remain same-origin under /api.
BACKEND_INTERNAL_URL=http://127.0.0.1:8000

# Email (console backend is permitted only in development)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
DEFAULT_FROM_EMAIL=no-reply@example.invalid
EMAIL_HOST=localhost
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=true

# Stripe secrets are server-side only. Never prefix them with NEXT_PUBLIC_.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_ENVIRONMENT=test
# Set true only after explicit approval to use an sk_live_ key.
STRIPE_LIVE_MODE_CONFIRMED=false

# Shared production runtime paths
DJANGO_STATIC_ROOT=
DJANGO_MEDIA_ROOT=

# Encrypted Airproche-only backups
BACKUP_DIR=
BACKUP_RETENTION_DAYS=14
BACKUP_ENCRYPTION_KEY=
# Operator scripts set this only after Zoho, Stripe test, and staff CIDRs are supplied.
AIRPROCHE_SECRETS_CONFIGURED=false
